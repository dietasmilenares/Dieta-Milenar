upmilenar(){ rm -rf /home/ubuntu/Dieta-Milenar && git clone https://github.com/dietasmilenares/Dieta-Milenar /home/ubuntu/Dieta-Milenar; echo -e "\n\033[1;33m  Qual acao deseja executar?\033[0m\n  [1] install.sh\n  [2] install2.sh\n  [3] Update S.O\n"; read -rp "  Escolha [1/2/3]: " _INS; case $_INS in 1) sudo -i bash
/home/ubuntu/Dieta-Milenar/install.sh ;; 2) sudo -i bash /home/ubuntu/Dieta-Milenar/install2.sh ;; 3) GOLD='\033[38;5;220m'; BOLD='\033[1m'; NC='\033[0m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; DIM='\033[2m'; spin(){ local pid=$1 msg=$2 frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'; while kill -0 $pid 2>/dev/null; do for((i=0;i<${#frames};i++));do
printf "\r  ${CYAN}${frames:$i:1}${NC} $msg"; sleep 0.1; done; done;
printf "\r  ${GREEN}[✔]${NC} $msg\n"; }; echo -e "\n${GOLD}${BOLD}  ── Atualizando S.O ─────────────────────────────${NC}\n"; apt-get update -qq >/dev/null 2>&1 & spin $! "Atualizando repositorios..."; apt-get upgrade -y -qq >/dev/null 2>&1 & spin $! "Instalando atualizacoes..."; apt-get autoremove -y --purge -qq >/dev/null 2>&1 & spin $! "Removendo pacotes..."; echo -e "\n${GOLD}${BOLD}  ── Diagnostico ────────────────────────────────${NC}\n"; if [ -f /var/run/reboot-required ]; then echo -e "  ${YELLOW}[!]${NC} Reboot necessario:\n"; [ -f /var/run/reboot-required.pkgs ] && while IFS= read -r p; do echo -e "  ${YELLOW}*${NC} $p"; done < /var/run/reboot-required.pkgs; echo -e "\n
${DIM}Execute: reboot${NC}\n"; else echo -e "  ${GREEN}[✔]${NC} Nenhum reboot necessario.\n"; fi ;; *) echo -e "\033[0;31m[✘]\033[0m Invalido." ;; esac; }